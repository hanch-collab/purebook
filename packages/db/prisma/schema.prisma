generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  SUPER_ADMIN
  MANAGER
  SALON_ADMIN
  ADMIN
}

enum SpecialistRole {
  MANAGER
  STAFF
  FLOOR
}

enum AppointmentStatus {
  UNCONFIRMED
  CONFIRMED
  NO_SHOW
  CANCELLED
}

enum RecurrenceFrequency {
  OFF
  EVERY_1_WEEK
  EVERY_2_WEEKS
  EVERY_3_WEEKS
  MONTHLY
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum RecurrenceEnd {
  NEVER
  ON_DATE
}

enum BlockTimeReason {
  LUNCH
  HOLIDAY
  SICK
  TRAINING
  OTHER
}

enum BookingChannel {
  IN_PERSON
  PHONE
  EMAIL
  WEBSITE
  FACEBOOK
  INSTAGRAM
  TIKTOK
  GROUPON
  OTHER
}

enum ReminderType {
  SMS
  WHATSAPP
  EMAIL
  BOTH
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum CommissionType {
  STANDARD
  SPECIAL
}

enum WaitlistStatus {
  WAITLIST
  CONFIRMED
  NO_SHOW
  CANCELLED
}

enum AppointmentHistoryAction {
  UPDATE
  SPLIT_OLD
  CREATE_CHILD
  DETACH_SINGLE
}

enum AppointmentTimelineAction {
  CREATED
  NOTE_ADDED
  UPDATED
  APPOINTMENT_DELETED
  APPOINTMENT_INSTANCE_DELETED
  FUTURE_APPOINTMENTS_DELETED
  APPOINTMENT_PAID
  NOTE_UPDATED
  STATUS_CHANGED
}

enum CustomerTimelineAction {
  CUSTOMER_CREATED
  NOTE_ADDED
  NOTE_UPDATED
  VISITS_UPDATED_MANUAL
  APPOINTMENT_DELETED
  WAITLIST_UPDATED
  VISITS_UPDATED
  CUSTOMER_UPDATED
  UNDO
  CUSTOMER_DELETED
  STATUS_CHANGED
  LOYALTY_TIER_UPDATED
  LOYALTY_POINTS_UPDATED
  APPOINTMENT_CREATED
  FILES_UPLOADED
  FILE_DELETED
  WAITLIST_CREATED
  DEPOSIT_UPDATED
  APPOINTMENT_PAID
  APPOINTMENT_STATUS_UPDATED
  APPOINTMENT_INSTANCE_DELETED
  FUTURE_APPOINTMENTS_DELETED
}

enum CancellationScope {
  THIS_OCCURRENCE
  THIS_AND_FUTURE
}

enum CancellationResponsibleParty {
  CUSTOMER
  SALON
}

enum CustomerNoteType {
  ALLERGY
  FORMULA
  GENERAL
  POPUP_NOTE
}

enum EngagementTier {
  REGULAR
  SEASONAL
  LAPSED
}

enum SubscriptionTier {
  BASE
  GROWTH
  PRO
  ENTERPRISE
}

enum SubscriptionBillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum PromotionStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  DRAFT
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum PaymentType {
  CARD
  CASH
  CREDIT
  VOUCHER
  MIXED
}

model Site {
  id                               String                   @id @default(cuid())
  siteId                           String                   @unique
  salonName                        String
  location                         String?
  contactNumber                    String?
  email                            String?
  passwordHash                     String
  memberId                         String
  cancellationNoticePeriodHours    Int                      @default(24)
  depositForfeitOnLateCancellation Boolean                  @default(true)
  subscriptionTier                 SubscriptionTier         @default(BASE)
  subscriptionStatus               SubscriptionStatus       @default(TRIALING)
  subscriptionBillingCycle         SubscriptionBillingCycle @default(MONTHLY)
  trialEndsAt                      DateTime?
  stripeCustomerId                 String?
  stripeSubscriptionId             String?
  currentPeriodEnd                 DateTime?
  stripeAccountId                  String?
  paymentsEnabled                  Boolean                  @default(false)
  waitlistEnabled                  Boolean                  @default(false)
  workingHours                     Json?
  member                           Member                   @relation(fields: [memberId], references: [id])
  specialists                      Specialist[]
  customers                        Customer[]
  categories                       Category[]
  appointments                     Appointment[]
  blockTimes                       BlockTime[]
  waitlistEntries                  WaitlistEntry[]
  loyaltyTiers                     LoyaltyTier[]
  promotions                       Promotion[]
  suppliers                        Supplier[]
  inventory                        InventoryItem[]
  purchaseOrders                   PurchaseOrder[]
  notificationTemplates            NotificationTemplate[]
  engagementTierSnapshots          EngagementTierSnapshot[]
  createdAt                        DateTime                 @default(now())
  updatedAt                        DateTime                 @updatedAt
  @@map("sites")
}

model Member {
  id           String     @id @default(cuid())
  memberId     String     @unique
  firstName    String
  lastName     String
  email        String     @unique
  passwordHash String
  role         MemberRole @default(ADMIN)
  sites        Site[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@map("members")
}

model Specialist {
  id                    String                   @id @default(cuid())
  staffId               String                   @unique
  siteId                String
  memberId              String
  title                 String?
  firstName             String
  middleName            String?
  lastName              String
  birthDate             DateTime?
  phoneMobile           String
  phoneHome             String?
  email                 String                   @unique
  address1              String?
  address2              String?
  address3              String?
  zip                   String?
  gender                String?
  profilePhoto          String?
  pin                   String?
  role                  SpecialistRole           @default(STAFF)
  status                String
  startDate             DateTime?
  endDate               DateTime?
  reviewDate            DateTime?
  bookingLink           String?
  bookOnline            Boolean                  @default(true)
  notesPrivate          String?
  notesPublic           String?
  monthlyRevenueTarget  Decimal?                 @db.Decimal(10, 2)
  commissionRate        Decimal?                 @db.Decimal(5, 2)
  site                  Site                     @relation(fields: [siteId], references: [id])
  serviceQualifications ServiceQualification[]
  availability          SpecialistAvailability[]
  appointmentServices   AppointmentService[]
  blockTimes            BlockTime[]
  appointmentNotes      AppointmentNote[]
  waitlistServices      WaitlistService[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  @@map("specialists")
}

model ServiceQualification {
  id           String     @id @default(cuid())
  specialistId String
  serviceId    String
  specialist   Specialist @relation(fields: [specialistId], references: [id])
  service      Service    @relation(fields: [serviceId], references: [id])
  @@unique([specialistId, serviceId])
  @@map("service_qualifications")
}

model SpecialistAvailability {
  id            String                     @id @default(cuid())
  specialistId  String
  allOfDays     Boolean                    @default(false)
  specialist    Specialist                 @relation(fields: [specialistId], references: [id])
  timeSlots     AvailabilityTimeSlot[]
  specificDates SpecificDateAvailability[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  @@map("specialist_availability")
}

model AvailabilityTimeSlot {
  id             String                 @id @default(cuid())
  availabilityId String
  startTime      String
  endTime        String
  availability   SpecialistAvailability @relation(fields: [availabilityId], references: [id])
  @@map("availability_time_slots")
}

model SpecificDateAvailability {
  id             String                 @id @default(cuid())
  availabilityId String
  date           DateTime
  availability   SpecialistAvailability @relation(fields: [availabilityId], references: [id])
  timeSlots      SpecificDateTimeSlot[]
  @@map("specific_date_availability")
}

model SpecificDateTimeSlot {
  id             String                   @id @default(cuid())
  specificDateId String
  startTime      String
  endTime        String
  specificDate   SpecificDateAvailability @relation(fields: [specificDateId], references: [id])
  @@map("specific_date_time_slots")
}

model Category {
  id          String         @id @default(cuid())
  categoryId  String         @unique
  siteId      String
  memberId    String
  name        String
  description String?
  status      CategoryStatus @default(ACTIVE)
  notes       String?
  isArchived  Boolean        @default(false)
  archivedAt  DateTime?
  site        Site           @relation(fields: [siteId], references: [id])
  services    Service[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  @@map("categories")
}

model Service {
  id                   String                 @id @default(cuid())
  serviceId            String                 @unique
  siteId               String
  categoryId           String
  name                 String
  description          String?
  department           String
  price                Decimal                @db.Decimal(10, 2)
  duration             Int
  depositRequired      Boolean                @default(false)
  serviceImage         String?
  appointmentColour    String
  backgroundColour     String
  loyaltyValue         Int                    @default(100)
  loyaltyEnabled       Boolean                @default(false)
  commission           Decimal?               @db.Decimal(5, 2)
  commissionBonus      Decimal?               @db.Decimal(10, 2)
  commissionType       CommissionType?
  skinTestRequired     Boolean                @default(false)
  bookableOnline       Boolean                @default(true)
  status               ServiceStatus          @default(ACTIVE)
  isArchived           Boolean                @default(false)
  archivedAt           DateTime?
  notes                String?
  level                String                 @default("Parent")
  parentServiceId      String?
  parentService        Service?               @relation("ServiceVariants", fields: [parentServiceId], references: [id])
  variants             Service[]              @relation("ServiceVariants")
  category             Category               @relation(fields: [categoryId], references: [id])
  qualifiedSpecialists ServiceQualification[]
  appointmentServices  AppointmentService[]
  waitlistServices     WaitlistService[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  @@map("services")
}

model Customer {
  id                         String                   @id @default(cuid())
  customerId                 String                   @unique
  siteId                     String
  title                      String?
  firstName                  String
  middleName                 String?
  lastName                   String
  birthDate                  DateTime?
  customerSinceDate          DateTime?
  countryCode                String?
  phoneMobile                String
  phoneHome                  String?
  email                      String
  address1                   String?
  address2                   String?
  address3                   String?
  zip                        String?
  gender                     String?
  lastVisitDate              DateTime?
  numberOfVisits             Int                      @default(0)
  totalNumberOfVisits        Int                      @default(0)
  cancelledAppointmentsCount Int                      @default(0)
  totalNumberOfNoShows       Int                      @default(0)
  visitsOverride             Boolean                  @default(false)
  manualBaseVisits           Int                      @default(0)
  manualBaseDate             DateTime?
  engagementTier             EngagementTier           @default(REGULAR)
  personalVisitIntervalDays  Int?
  currentGapDays             Int?
  atRiskRatio                Decimal?                 @db.Decimal(5, 2)
  isAtRisk                   Boolean                  @default(false)
  loyaltyTierId              String?
  pointsBalance              Int                      @default(0)
  pointsEarned               Int                      @default(0)
  pointsRedeemed             Int                      @default(0)
  pointsExpiryDate           DateTime?
  depositAmount              Decimal?                 @db.Decimal(10, 2)
  depositPaidDate            DateTime?
  depositSpentDate           DateTime?
  skinTestDate               DateTime?
  skinTestPerformedBy        String?
  remindersEnabled           Boolean                  @default(true)
  reminderType               ReminderType             @default(SMS)
  isNew                      Boolean                  @default(true)
  isDeleted                  Boolean                  @default(false)
  deletedAt                  DateTime?
  site                       Site                     @relation(fields: [siteId], references: [id])
  loyaltyTier                LoyaltyTier?             @relation(fields: [loyaltyTierId], references: [id])
  appointments               Appointment[]
  customerNotes              CustomerNote[]
  customerFiles              CustomerFile[]
  waitlistEntries            WaitlistEntry[]
  customerHistory            CustomerHistory[]
  customerTimeline           CustomerTimeline[]
  engagementSnapshots        EngagementTierSnapshot[]
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  @@map("customers")
}

model CustomerNote {
  id          String           @id @default(cuid())
  customerId  String
  type        CustomerNoteType
  description String
  createdBy   String
  isDeleted   Boolean          @default(false)
  customer    Customer         @relation(fields: [customerId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@map("customer_notes")
}

model CustomerFile {
  id         String   @id @default(cuid())
  customerId String
  name       String
  url        String
  uploadedBy String   @default("Salon Admin")
  customer   Customer @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())
  @@map("customer_files")
}

model CustomerHistory {
  id         String   @id @default(cuid())
  customerId String
  action     String   @default("update")
  updatedBy  String?
  oldData    Json
  customer   Customer @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())
  @@map("customer_history")
}

model CustomerTimeline {
  id          String                 @id @default(cuid())
  customerId  String
  action      CustomerTimelineAction
  description String
  actionBy    String?
  customer    Customer               @relation(fields: [customerId], references: [id])
  createdAt   DateTime               @default(now())
  @@map("customer_timeline")
}

model EngagementTierSnapshot {
  id           String         @id @default(cuid())
  customerId   String
  siteId       String
  tier         EngagementTier
  snapshotDate DateTime
  customer     Customer       @relation(fields: [customerId], references: [id])
  site         Site           @relation(fields: [siteId], references: [id])
  createdAt    DateTime       @default(now())
  @@unique([customerId, snapshotDate])
  @@map("engagement_tier_snapshots")
}

model Appointment {
  id                  String               @id @default(cuid())
  siteId              String
  customerId          String
  parentAppointmentId String?
  parentAppointment   Appointment?         @relation("RecurringSeries", fields: [parentAppointmentId], references: [id])
  childAppointments   Appointment[]        @relation("RecurringSeries")
  bookedBy            String
  bookingChannel      BookingChannel?
  appointmentDate     DateTime
  repeat              RecurrenceFrequency  @default(OFF)
  repeatOn            DayOfWeek?
  ends                RecurrenceEnd        @default(NEVER)
  endDate             DateTime?
  rrule               String?
  deletedInstances    DateTime[]
  status              AppointmentStatus    @default(UNCONFIRMED)
  isRebook            Boolean              @default(false)
  isDeleted           Boolean              @default(false)
  waitlistConvert     Boolean              @default(false)
  site                Site                 @relation(fields: [siteId], references: [id])
  customer            Customer             @relation(fields: [customerId], references: [id])
  services            AppointmentService[]
  occurrences         AppointmentOccurrence[]
  statusUpdates       AppointmentStatusUpdate[]
  exceptions          AppointmentException[]
  attachments         AppointmentAttachment[]
  notes               AppointmentNote[]
  history             AppointmentHistory[]
  timeline            AppointmentTimeline[]
  cancellation        Cancellation?
  deletedRecord       DeletedAppointment?
  checkouts           Checkout[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  @@map("appointments")
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  specialistId  String
  startTime     String
  endTime       String?
  price         Decimal     @db.Decimal(10, 2)
  duration      Int
  isPreferred   Boolean     @default(true)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])
  specialist    Specialist  @relation(fields: [specialistId], references: [id])
  @@map("appointment_services")
}

model AppointmentOccurrence {
  id            String      @id @default(cuid())
  appointmentId String
  date          DateTime
  checkoutId    String?
  checkoutDone  Boolean     @default(false)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  @@map("appointment_occurrences")
}

model AppointmentStatusUpdate {
  id            String            @id @default(cuid())
  appointmentId String
  date          DateTime
  status        AppointmentStatus
  updatedAt     DateTime          @default(now())
  appointment   Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  @@map("appointment_status_updates")
}

model AppointmentException {
  id            String                       @id @default(cuid())
  appointmentId String
  instanceDate  DateTime
  futureUpdate  Boolean                      @default(false)
  newDate       DateTime?
  appointment   Appointment                  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  services      AppointmentExceptionService[]
  @@map("appointment_exceptions")
}

model AppointmentExceptionService {
  id           String               @id @default(cuid())
  exceptionId  String
  serviceId    String?
  specialistId String?
  startTime    String?
  endTime      String?
  price        Decimal              @db.Decimal(10, 2)
  duration     Int
  isPreferred  Boolean              @default(false)
  exception    AppointmentException @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  @@map("appointment_exception_services")
}

model AppointmentAttachment {
  id            String      @id @default(cuid())
  appointmentId String
  fileName      String
  fileUrl       String
  uploadedBy    String      @default("Salon Admin")
  uploadedAt    DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  @@map("appointment_attachments")
}

model AppointmentNote {
  id              String      @id @default(cuid())
  appointmentId   String
  specialistId    String
  appointmentDate DateTime
  date            DateTime
  time            String
  note            String      @default("")
  createdBy       String      @default("Salon Admin")
  isDeleted       Boolean     @default(false)
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  specialist      Specialist  @relation(fields: [specialistId], references: [id])
  attachments     NoteAttachment[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@map("appointment_notes")
}

model NoteAttachment {
  id     String          @id @default(cuid())
  noteId String
  name   String
  url    String
  note   AppointmentNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  @@map("note_attachments")
}

model AppointmentHistory {
  id            String                   @id @default(cuid())
  appointmentId String
  action        AppointmentHistoryAction @default(UPDATE)
  updatedBy     String?
  oldData       Json
  meta          Json                     @default("{}")
  appointment   Appointment              @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime                 @default(now())
  @@map("appointment_history")
}

model AppointmentTimeline {
  id                   String                    @id @default(cuid())
  appointmentId        String
  action               AppointmentTimelineAction
  message              String
  createdBy            String
  linkedAppointmentIds String[]
  appointment          Appointment               @relation(fields: [appointmentId], references: [id])
  createdAt            DateTime                  @default(now())
  @@map("appointment_timeline")
}

model Cancellation {
  id                 String                       @id @default(cuid())
  appointmentId      String                       @unique
  reason             String?
  responsibleParty   CancellationResponsibleParty @default(CUSTOMER)
  scope              CancellationScope            @default(THIS_OCCURRENCE)
  messageToCustomer  String?
  notifyChannels     ReminderType[]
  chargeDeposit      Boolean                      @default(false)
  chargedAmount      Decimal                      @db.Decimal(10, 2) @default(0)
  withinNoticePeriod Boolean                      @default(false)
  addedToHistory     Boolean                      @default(true)
  cancelledDate      DateTime                     @default(now())
  appointment        Appointment                  @relation(fields: [appointmentId], references: [id])
  createdAt          DateTime                     @default(now())
  @@map("cancellations")
}

model DeletedAppointment {
  id              String      @id @default(cuid())
  appointmentId   String      @unique
  deletedBy       String
  reason          String      @default("User deleted")
  appointmentDate DateTime
  virtualId       String?
  deleteAll       Boolean     @default(false)
  deleteFuture    Boolean     @default(false)
  deletedAt       DateTime    @default(now())
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@map("deleted_appointments")
}

model UpdateStatusHistory {
  id             String            @id @default(cuid())
  appointmentId  String
  updatedDate    DateTime
  previousStatus AppointmentStatus
  newStatus      AppointmentStatus
  updatedAt      DateTime          @default(now())
  @@map("update_status_history")
}

model Checkout {
  id                    String             @id @default(cuid())
  appointmentId         String
  appointmentDate       DateTime
  paymentType           PaymentType
  tips                  Decimal?           @db.Decimal(10, 2)
  useDeposit            Boolean            @default(false)
  depositAmount         Decimal            @db.Decimal(10, 2) @default(0)
  subTotal              Decimal            @db.Decimal(10, 2)
  totalServiceDiscount  Decimal            @db.Decimal(10, 2) @default(0)
  totalAfterDiscount    Decimal            @db.Decimal(10, 2)
  finalTotalDue         Decimal            @db.Decimal(10, 2)
  checkoutDate          DateTime
  stripePaymentIntentId String?
  appointment           Appointment        @relation(fields: [appointmentId], references: [id])
  lineItems             CheckoutLineItem[]
  overallDiscount       CheckoutDiscount?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  @@map("checkouts")
}

model CheckoutLineItem {
  id             String        @id @default(cuid())
  checkoutId     String
  serviceId      String
  price          Decimal       @db.Decimal(10, 2)
  discountType   DiscountType?
  discountValue  Decimal?      @db.Decimal(10, 2)
  discountReason String?
  checkout       Checkout      @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  @@map("checkout_line_items")
}

model CheckoutDiscount {
  id            String       @id @default(cuid())
  checkoutId    String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  reason        String?
  checkout      Checkout     @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  @@map("checkout_discounts")
}

model BlockTime {
  id                String              @id @default(cuid())
  siteId            String
  specialistId      String
  reason            BlockTimeReason
  description       String?
  startDate         DateTime
  endDate           DateTime?
  startTime         String
  endTime           String
  isAllDay          Boolean
  repeat            RecurrenceFrequency @default(OFF)
  repeatOn          DayOfWeek[]
  endsType          RecurrenceEnd       @default(NEVER)
  endsDate          DateTime?
  rrule             String?
  deletedInstances  DateTime[]
  parentId          String?
  isDeleted         Boolean             @default(false)
  site              Site                @relation(fields: [siteId], references: [id])
  specialist        Specialist          @relation(fields: [specialistId], references: [id])
  parentBlock       BlockTime?          @relation("BlockTimeSeries", fields: [parentId], references: [id])
  childBlocks       BlockTime[]         @relation("BlockTimeSeries")
  modifiedInstances BlockTimeModification[]
  history           BlockTimeHistory[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  @@map("block_times")
}

model BlockTimeModification {
  id           String    @id @default(cuid())
  blockTimeId  String
  date         DateTime
  startTime    String
  endTime      String
  updateFuture Boolean   @default(false)
  blockTime    BlockTime @relation(fields: [blockTimeId], references: [id], onDelete: Cascade)
  @@map("block_time_modifications")
}

model BlockTimeHistory {
  id          String    @id @default(cuid())
  blockTimeId String
  oldData     Json
  updatedBy   String?
  newIds      String[]
  blockTime   BlockTime @relation(fields: [blockTimeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("block_time_history")
}

model WaitlistEntry {
  id                 String              @id @default(cuid())
  siteId             String
  customerId         String
  parentWaitlistId   String?
  parentEntry        WaitlistEntry?      @relation("WaitlistSeries", fields: [parentWaitlistId], references: [id])
  childEntries       WaitlistEntry[]     @relation("WaitlistSeries")
  bookedBy           String
  bookingChannel     BookingChannel
  currentWaitingDate DateTime
  repeat             RecurrenceFrequency @default(OFF)
  status             WaitlistStatus      @default(WAITLIST)
  isWaitlist         Boolean             @default(true)
  isDeleted          Boolean             @default(false)
  deletedChildIds    String[]
  site               Site                @relation(fields: [siteId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  services           WaitlistService[]
  waitingDates       WaitlistDate[]
  notes              WaitlistNote[]
  attachments        WaitlistAttachment[]
  timeline           WaitlistTimeline[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  @@map("waitlist_entries")
}

model WaitlistService {
  id           String        @id @default(cuid())
  waitlistId   String
  serviceId    String
  specialistId String
  startTime    String
  endTime      String?
  price        Decimal       @db.Decimal(10, 2)
  duration     Int
  isPreferred  Boolean       @default(true)
  waitlist     WaitlistEntry @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id])
  specialist   Specialist    @relation(fields: [specialistId], references: [id])
  @@map("waitlist_services")
}

model WaitlistDate {
  id         String        @id @default(cuid())
  waitlistId String
  date       String
  startTime  String
  waitlist   WaitlistEntry @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  @@map("waitlist_dates")
}

model WaitlistNote {
  id           String        @id @default(cuid())
  waitlistId   String
  specialistId String
  date         DateTime
  time         String
  note         String        @default("")
  createdBy    String        @default("Salon Admin")
  isDeleted    Boolean       @default(false)
  attachFiles  String[]
  waitlist     WaitlistEntry @relation(fields: [waitlistId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@map("waitlist_notes")
}

model WaitlistAttachment {
  id         String        @id @default(cuid())
  waitlistId String
  fileName   String
  fileUrl    String
  uploadedBy String        @default("Salon Admin")
  uploadedAt DateTime      @default(now())
  waitlist   WaitlistEntry @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  @@map("waitlist_attachments")
}

model WaitlistTimeline {
  id         String        @id @default(cuid())
  waitlistId String
  action     String
  message    String
  createdBy  String
  waitlist   WaitlistEntry @relation(fields: [waitlistId], references: [id])
  createdAt  DateTime      @default(now())
  @@map("waitlist_timeline")
}

model LoyaltyTier {
  id                String     @id @default(cuid())
  siteId            String
  loyaltyId         String     @unique
  tierName          String
  tierType          String
  tierValue         Decimal    @db.Decimal(10, 2)
  minPointsRequired Int
  reward            String     @default("100")
  status            String     @default("active")
  site              Site       @relation(fields: [siteId], references: [id])
  customers         Customer[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  @@map("loyalty_tiers")
}

model Promotion {
  id                String          @id @default(cuid())
  siteId            String
  name              String
  description       String?
  status            PromotionStatus @default(DRAFT)
  discountType      DiscountType
  discountValue     Decimal         @db.Decimal(10, 2)
  startDate         DateTime
  endDate           DateTime?
  noEndDate         Boolean         @default(false)
  activeDays        DayOfWeek[]
  appliesTo         String[]
  revenueAttributed Decimal         @db.Decimal(10, 2) @default(0)
  usageCount        Int             @default(0)
  site              Site            @relation(fields: [siteId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  @@map("promotions")
}

model Supplier {
  id             String          @id @default(cuid())
  siteId         String
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  notes          String?
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  site           Site            @relation(fields: [siteId], references: [id])
  products       InventoryItem[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  @@map("suppliers")
}

model InventoryItem {
  id                 String              @id @default(cuid())
  siteId             String
  supplierId         String?
  name               String
  brand              String?
  sku                String?
  description        String?
  category           String?
  unitCost           Decimal?            @db.Decimal(10, 2)
  retailPrice        Decimal?            @db.Decimal(10, 2)
  currentStock       Int                 @default(0)
  minimumStock       Int                 @default(0)
  unit               String              @default("unit")
  isRetail           Boolean             @default(false)
  isArchived         Boolean             @default(false)
  archivedAt         DateTime?
  site               Site                @relation(fields: [siteId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  @@map("inventory_items")
}

model StockMovement {
  id          String        @id @default(cuid())
  itemId      String
  type        String
  quantity    Int
  note        String?
  recordedBy  String        @default("Salon Admin")
  referenceId String?
  item        InventoryItem @relation(fields: [itemId], references: [id])
  createdAt   DateTime      @default(now())
  @@map("stock_movements")
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  siteId     String
  supplierId String
  orderRef   String?
  status     String              @default("DRAFT")
  notes      String?
  orderedAt  DateTime?
  receivedAt DateTime?
  site       Site                @relation(fields: [siteId], references: [id])
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  items      PurchaseOrderItem[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  inventoryItemId  String
  quantityOrdered  Int
  quantityReceived Int           @default(0)
  unitCost         Decimal       @db.Decimal(10, 2)
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  @@map("purchase_order_items")
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  siteId    String
  type      String
  channel   String
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  site      Site     @relation(fields: [siteId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([siteId, type, channel])
  @@map("notification_templates")
}

model SubscriptionEvent {
  id          String   @id @default(cuid())
  siteId      String
  event       String
  payload     Json
  processedAt DateTime @default(now())
  @@map("subscription_events")
}
