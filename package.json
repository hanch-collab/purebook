{
  "name": "purebook",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/web", "packages/db"],
  "scripts": {
    "dev":       "npm run dev --workspace=apps/web",
    "build":     "npm run build --workspace=apps/web",
